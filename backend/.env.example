# Copy to .env and adjust. Values here are optional; defaults work for local dev.

# Production (Vercel + Neon): set DATABASE_URL to the Neon connection string
# (postgres:// or postgresql://). The app uses PostgreSQL automatically.
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Local SQLite (omit DATABASE_URL or use sqlite:///…)
# EXPENSE_TRACKER_DB=expense_tracker.db
# DATABASE_URL=sqlite:////tmp/expense_tracker.db

# Browser origins allowed to call the API (comma-separated). Omit or * for dev only.
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Flask
# FLASK_APP=app.py
# FLASK_DEBUG=1
# FLASK_SECRET_KEY=change-me-in-production

# JWT signing (defaults to FLASK_SECRET_KEY if unset)
# JWT_SECRET_KEY=another-long-random-string

# When migrating old rows without user_id, first user is created if needed:
# MIGRATION_ADMIN_EMAIL=legacy@migrated.local
# MIGRATION_ADMIN_PASSWORD=ChangeThisPassword1!

# Tests / CI: skip importing backend/*.csv into the DB
# DISABLE_CSV_IMPORT=1
